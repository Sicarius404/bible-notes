{
  "name": "bible-notes",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@bible-notes/web",
    "dev:mobile": "turbo dev --filter=@bible-notes/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@bible-notes/web",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.9.5",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=24.0.0"
  }
}