# Build stage
FROM node:24-slim AS builder

WORKDIR /app

# Build-time env vars for Next.js (injected by Coolify at build time)
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_POCKETBASE_URL
ENV NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}
ENV NEXT_PUBLIC_POCKETBASE_URL=${NEXT_PUBLIC_POCKETBASE_URL}

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.7.0 --activate

# Copy workspace config
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY tsconfig.base.json ./

# Copy shared packages
COPY packages/shared/package.json packages/shared/
COPY packages/shared/ packages/shared/
COPY packages/pocketbase-client/package.json packages/pocketbase-client/
COPY packages/pocketbase-client/ packages/pocketbase-client/

# Copy web app
COPY apps/web/package.json apps/web/
COPY apps/web/ apps/web/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Clean any stale incremental build info to ensure fresh compilation
RUN find . -name '*.tsbuildinfo' -delete

# Build shared packages first
RUN pnpm --filter @bible-notes/shared build

# Build pocketbase-client
RUN pnpm --filter @bible-notes/pocketbase-client build

# Build web app
RUN pnpm --filter @bible-notes/web build

# Production stage
FROM node:24-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy built app
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "apps/web/server.js"]