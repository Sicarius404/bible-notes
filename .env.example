# PocketBase — Internal URL (used by SSR/server-side)
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=changeme

# Next.js — Public URL (used by browser/client-side)
# In dev: http://localhost:8090 (direct PocketBase access)
# In Docker: /api (proxied through Nginx)
# In production: https://yourdomain.com/api
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bible Gateway
NEXT_PUBLIC_BIBLE_GATEWAY_URL=https://www.biblegateway.com/passage/
NEXT_PUBLIC_DEFAULT_BIBLE_VERSION=NIV

# Expo (mobile)
EXPO_PUBLIC_POCKETBASE_URL=http://localhost:8090