{
  "expo": {
    "name": "Bible Notes",
    "slug": "bible-notes",
    "scheme": "biblenotes",
    "version": "0.1.0",
    "orientation": "portrait",
      "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.za.zonit.biblenotes"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "co.za.zonit.biblenotes"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Bible Notes to use Face ID for secure login."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
